{
    "name": "lambda-cloud-cli",
    "version": "0.3.0",
    "description": "Lambda Cloud CLI tool with interactive TUI and MCP server for GPU instance management",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/jwjohns/Lambda-Cloud-CLI.git"
    },
    "keywords": [
        "lambda",
        "gpu",
        "cloud",
        "cli",
        "mcp",
        "tui",
        "ai",
        "h100",
        "gh200"
    ],
    "type": "module",
    "bin": {
        "lambda": "./dist/index.js",
        "lambda-cli": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "conf": "^13.1.0",
        "ink": "^5.2.0",
        "ink-spinner": "^5.0.0",
        "node-ssh": "^13.2.1",
        "react": "^18.3.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.19.15",
        "@types/react": "^18.3.18",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.2.4"
    }
}